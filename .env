import os
from dotenv import load_dotenv

# Tự động tải các cấu hình ẩn từ file .env lên hệ thống
load_dotenv()

print("==================================================")
print("   KẾT QUẢ CHẠY CÁC BÀI TOÁN TỪ CẤU HÌNH .ENV     ")
print("==================================================\n")

# 1. BÀI TOÁN: TÍNH GIAI THỪA
def tinh_giai_thua(n):
    if n == 0 or n == 1:
        return 1
    giai_thua = 1
    for i in range(2, n + 1):
        giai_thua *= i
    return giai_thua

# Lấy số từ file .env, chuyển từ dạng chữ (str) sang số nguyên (int)
so = int(os.getenv("SO_GIAI_THUA", 5))
print(f"-> Giai thừa của {so} là: {tinh_giai_thua(so)}")
print("-" * 50)


# 2. BÀI TOÁN: TÍNH GIÁ TRỊ TRUNG BÌNH CỦA DÃY SỐ
def tinh_trung_binh(day_so):
    if len(day_so) == 0:
        return 0
    return sum(day_so) / len(day_so)

# Lấy chuỗi số từ .env, cắt nhau bởi dấu phẩy và chuyển thành list số nguyên
chuoi_so = os.getenv("DANH_SACH_SO", "15,20,25,30,35")
danh_sach = [int(x) for x in chuoi_so.split(",")]
print(f"-> Dãy số phân tích: {danh_sach}")
print(f"-> Giá trị trung bình của dãy số là: {tinh_trung_binh(danh_sach)}")
print("-" * 50)


# 3. BÀI TOÁN: TÍNH LỢI NHUẬN SAU 12 THÁNG
def tinh_loi_nhuan_sau_12_thang(tien_ban_dau, lai_suat_thang):
    so_thang = 12
    tong_tien = tien_ban_dau * ((1 + lai_suat_thang) ** so_thang)
    loi_nhuan = tong_tien - tien_ban_dau
    return tong_tien, loi_nhuan

# Lấy vốn và lãi suất từ .env (ép kiểu float để tính toán số thập phân)
von = float(os.getenv("VON_BAN_DAU", 10000000))
lai_suat = float(os.getenv("LAI_SUAT_THANG", 0.015))

tong_ket, tien_lai = tinh_loi_nhuan_sau_12_thang(von, lai_suat)

print(f"--- KẾT QUẢ ĐẦU TƯ SAU 12 THÁNG ---")
print(f"Số tiền gốc ban đầu : {von:,.0f} VNĐ")
print(f"Lợi nhuận (Tiền lãi): {tien_lai:,.0f} VNĐ")
print(f"Tổng tiền thu về    : {tong_ket:,.0f} VNĐ")
print("==================================================")